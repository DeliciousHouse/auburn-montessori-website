---
import { Image } from 'astro:assets';
import nav from '../data/navigation.json';
import site from '../data/site.json';
import ExternalLink from './ExternalLink.astro';
import StudentRegistrationButton from './StudentRegistrationButton.astro';
import { siteConfig } from '../config/siteConfig';
import logo from '../assets/brand/logo.webp';

type Props = { currentPath: string };
const { currentPath } = Astro.props as Props;

const isActive = (href: string) => {
  if (href === '/') return currentPath === '/';
  return currentPath === href || currentPath.startsWith(`${href}/`);
};

const primaryHrefs = ['/', '/about', '/programs', '/educators', '/fees-hours', '/admissions', '/contact'];
const primaryNav = nav.filter((item: {href:string}) => primaryHrefs.includes(item.href));
const secondaryNav = nav.filter((item: {href:string}) => !primaryHrefs.includes(item.href) && item.href !== '/');
---

<!-- Secondary utility bar -->
<div class="secondary-bar hidden border-b lg:block" style="background: var(--color-surface-alt); border-color: var(--color-border);">
  <div class="container-page flex h-9 items-center justify-end gap-1">
    {secondaryNav.map((item: {href:string; label:string}) => (
      <a
        class:list={[
          'rounded-md px-3 py-1 text-xs font-medium no-underline transition-colors whitespace-nowrap',
          isActive(item.href)
            ? 'text-[var(--color-primary)] bg-[var(--color-primary-light)]'
            : 'text-[var(--color-text-subtle)] hover:text-[var(--color-text)] hover:bg-[var(--color-neutral-100)]'
        ]}
        href={item.href}
        aria-current={isActive(item.href) ? 'page' : undefined}
      >
        {item.label}
      </a>
    ))}
    <span class="mx-1 h-4 w-px" style="background: var(--color-border);" aria-hidden="true"></span>
    <ExternalLink
      href={siteConfig.brightwheel.parentSignInUrl}
      class="rounded-md px-3 py-1 text-xs font-medium no-underline text-[var(--color-text-subtle)] hover:text-[var(--color-text)] hover:bg-[var(--color-neutral-100)] transition-colors whitespace-nowrap"
      ariaLabel="Parent Sign-In"
    >
      Parent Sign-In
    </ExternalLink>
    <a
      href="/schedule-a-tour"
      class="btn btn-primary btn-sm rounded-md whitespace-nowrap"
      aria-label="Schedule a Tour"
    >
      Schedule a Tour
    </a>
    <StudentRegistrationButton
      wrapperClass="relative"
      buttonClass="btn btn-outline btn-sm"
      helperClass="absolute right-0 top-full mt-1 w-56 rounded-md border bg-white px-2 py-1 text-right text-[11px] leading-tight shadow-sm"
      label="Register"
    />
  </div>
</div>

<!-- Primary header -->
<header class="sticky-header border-b bg-white/95 backdrop-blur-sm" style="border-color: var(--color-border);">
  <div class="container-page flex h-16 items-center justify-between gap-6">
    <!-- Logo + Wordmark -->
    <a class="flex shrink-0 items-center gap-2.5 no-underline" href="/" aria-label={`${site.shortName} home`}>
      <Image
        src={logo}
        alt=""
        width={70}
        height={70}
        densities={[1, 2]}
        class="h-10 w-10 rounded-lg object-contain"
        loading="eager"
        decoding="async"
      />
      <div class="hidden leading-tight sm:block">
        <div class="text-sm font-bold tracking-tight" style="color: var(--color-text);">{site.shortName}</div>
        <div class="text-xs" style="color: var(--color-text-subtle);">{site.tagline}</div>
      </div>
    </a>

    <!-- Desktop primary nav -->
    <nav class="hidden items-center gap-0.5 lg:flex" aria-label="Primary">
      {primaryNav.map((item: {href:string; label:string}) => (
        <a
          class:list={[
            'rounded-lg px-4 py-2.5 text-sm font-medium no-underline transition-colors whitespace-nowrap',
            isActive(item.href)
              ? 'bg-[var(--color-primary-light)] text-[var(--color-primary)]'
              : 'text-[var(--color-text-muted)] hover:bg-[var(--color-neutral-100)] hover:text-[var(--color-text)]'
          ]}
          href={item.href}
          aria-current={isActive(item.href) ? 'page' : undefined}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- Desktop CTA (hidden on lg since it's in secondary bar) -->
    <div class="hidden items-center gap-2 md:flex lg:hidden">
      <ExternalLink
        href={siteConfig.brightwheel.parentSignInUrl}
        class="btn btn-ghost btn-sm"
        ariaLabel="Parent Sign-In"
      >
        Parent Sign-In
      </ExternalLink>
      <a href="/schedule-a-tour" class="btn btn-primary btn-sm" aria-label="Schedule a Tour">
        Schedule a Tour
      </a>
      <StudentRegistrationButton
        wrapperClass="relative"
        buttonClass="btn btn-outline btn-sm"
        helperClass="absolute right-0 top-full mt-1 w-56 rounded-md border bg-white px-2 py-1 text-right text-[11px] leading-tight shadow-sm"
      />
    </div>

    <!-- Mobile menu toggle -->
    <details class="relative lg:hidden" id="mobile-menu" data-mobile-menu>
      <summary
        id="mobile-menu-toggle"
        class="btn btn-outline btn-sm cursor-pointer select-none list-none"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu-panel"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" aria-hidden="true">
          <path d="M3 5h14M3 10h14M3 15h14" />
        </svg>
        <span class="ml-1.5">Menu</span>
      </summary>

      <div
        id="mobile-menu-panel"
        class="absolute right-0 mt-2 w-[min(92vw,22rem)] rounded-xl border bg-white p-2 shadow-xl"
        style="border-color: var(--color-border);"
        aria-label="Mobile navigation"
      >
        <nav class="flex flex-col gap-0.5" aria-label="Mobile primary">
          {nav.map((item: {href:string; label:string}) => (
            <a
              class:list={[
                'rounded-lg px-3 py-2.5 text-sm font-medium no-underline transition-colors',
                isActive(item.href)
                  ? 'bg-[var(--color-primary-light)] text-[var(--color-primary)]'
                  : 'text-[var(--color-text-muted)] hover:bg-[var(--color-surface-alt)]'
              ]}
              href={item.href}
              aria-current={isActive(item.href) ? 'page' : undefined}
              data-mobile-nav-link
            >
              {item.label}
            </a>
          ))}
          <hr class="my-1 border-[var(--color-neutral-200)]" aria-hidden="true" />
          <ExternalLink
            href={siteConfig.brightwheel.parentSignInUrl}
            class="btn btn-outline w-full justify-center"
            ariaLabel="Parent Sign-In"
            data-mobile-nav-link
          >
            Parent Sign-In
          </ExternalLink>
          <a
            href="/schedule-a-tour"
            class="btn btn-primary w-full justify-center"
            aria-label="Schedule a Tour"
            data-mobile-nav-link
          >
            Schedule a Tour
          </a>
          <StudentRegistrationButton
            wrapperClass="w-full"
            buttonClass="btn btn-outline w-full justify-center"
            helperClass="mt-1 text-xs"
          />
        </nav>
      </div>
    </details>
  </div>
</header>

<script>
  (function () {
    const details = document.querySelector<HTMLDetailsElement>('#mobile-menu');
    const summary = document.querySelector<HTMLElement>('#mobile-menu-toggle');
    if (!details || !summary) return;

    const close = () => {
      details.removeAttribute('open');
      summary.setAttribute('aria-expanded', 'false');
      summary.focus();
    };

    details.querySelectorAll('[data-mobile-nav-link]').forEach((el) => {
      el.addEventListener('click', () => close());
    });

    details.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') { close(); e.preventDefault(); }
    });

    details.addEventListener('toggle', () => {
      summary.setAttribute('aria-expanded', details.open ? 'true' : 'false');
    });
  })();
</script>
