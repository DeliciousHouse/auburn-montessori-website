---
import Layout from '../layouts/Layout.astro';
import site from '../data/site.json';
import ExternalLink from '../components/ExternalLink.astro';
import Icon from '../components/Icon.astro';
import { siteConfig } from '../config/siteConfig';
import { siteInfo } from '../config/site';
import { buildFaqSchema, buildSchoolSchema } from '../lib/schema';
import logo from '../assets/brand/logo.webp';

const addressLine = `${site.address.street} ${site.address.city}, ${site.address.state} ${site.address.postalCode}`;
const mapUrl = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(addressLine)}`;
const mapEmbedUrl = `https://maps.google.com/maps?q=${encodeURIComponent(addressLine)}&t=&z=15&ie=UTF8&iwloc=&output=embed`;
const logoUrl = new URL(logo.src, siteInfo.canonicalBaseUrl).toString();
const pageSchema = buildSchoolSchema({ logoUrl });

const faqEntries = [
  {
    question: 'What is the address?',
    answer: `Auburn Montessori School is located at ${siteInfo.address.street}, ${siteInfo.address.city}, ${siteInfo.address.region} ${siteInfo.address.postalCode}.`
  },
  {
    question: 'How do I get directions/parking?',
    answer: 'Use the map link on this page for directions. Parking is available on-site for family drop-off, pickup, and school visits.'
  },
  {
    question: 'What is the best way to contact the school?',
    answer: `Call ${siteInfo.phone} for immediate help or email ${siteInfo.email} for general questions and tour requests.`
  },
  {
    question: 'When can I schedule a tour?',
    answer: 'Tours are available on weekdays at 11:00am, 1:30pm, or 2:30pm.'
  },
  {
    question: 'Do you have online contact forms?',
    answer: 'Tour requests on this page open your email client so you can send details directly to the school.'
  },
  {
    question: 'Where can I find program hours?',
    answer: 'Program hours and tuition details are listed on the Fees & Hours page.'
  }
];

const faqSchema = buildFaqSchema(faqEntries);
---

<Layout
  title="Contact"
  description="Contact Auburn Montessori School - The Children's House (address, phone, email)."
  heroTitle="Contact Us"
  heroLead="Get in touch with Auburn Montessori School - The Children's House."
  structuredData={[pageSchema, faqSchema]}
>
  <div class="section-band">
    <div class="container-page grid gap-8 lg:grid-cols-5">
      <!-- Contact cards -->
      <div class="space-y-5 lg:col-span-2">
        <div class="contact-item">
          <div class="contact-icon"><Icon name="location" size={20} /></div>
          <div>
            <div class="text-xs font-semibold uppercase tracking-wider" style="color: var(--color-neutral-500);">Address</div>
            <div class="mt-1 text-sm" style="color: var(--color-neutral-800);">
              {site.address.street}<br />
              {site.address.city}, {site.address.state} {site.address.postalCode}
            </div>
            <ExternalLink href={mapUrl} class="mt-1 inline-block text-sm font-semibold no-underline hover:underline">Open in maps</ExternalLink>
          </div>
        </div>

        <div class="contact-item">
          <div class="contact-icon"><Icon name="phone" size={20} /></div>
          <div>
            <div class="text-xs font-semibold uppercase tracking-wider" style="color: var(--color-neutral-500);">Phone</div>
            <a class="mt-1 block text-sm font-semibold" href={`tel:${site.phone}`}>{site.phone}</a>
          </div>
        </div>

        <div class="contact-item">
          <div class="contact-icon"><Icon name="mail" size={20} /></div>
          <div>
            <div class="text-xs font-semibold uppercase tracking-wider" style="color: var(--color-neutral-500);">Email</div>
            <a class="mt-1 block text-sm font-semibold" href={`mailto:${site.email}`}>{site.email}</a>
          </div>
        </div>

        <div class="contact-item">
          <div class="contact-icon"><Icon name="clock" size={20} /></div>
          <div>
            <div class="text-xs font-semibold uppercase tracking-wider" style="color: var(--color-neutral-500);">Office Hours</div>
            <p class="mt-1 text-sm" style="color: var(--color-neutral-700);">Program hours vary. See <a class="font-semibold" href="/fees-hours">Fees &amp; Hours</a> for details.</p>
          </div>
        </div>

        <hr class="divider" />

        <h2 class="text-sm font-bold" style="color: var(--color-neutral-900);">Request a Tour</h2>
        <p class="mt-1 text-xs" style="color: var(--color-neutral-600);">
          Tours are available weekdays at 11:00am, 1:30pm, or 2:30pm.
        </p>
        <p class="mt-1 text-xs" style="color: var(--color-neutral-500);">
          The form below opens your email client with a pre-filled tour request. We do not store tour requests on our servers; your message is sent only when you send the email.
        </p>
        <form id="tour-request-form" class="mt-4 space-y-3">
          <div>
            <label for="tour-parent-name" class="block text-xs font-semibold" style="color: var(--color-neutral-700);">Parent/Guardian Name <span aria-hidden="true">*</span></label>
            <input type="text" id="tour-parent-name" name="parentName" required autocomplete="name" class="mt-1 w-full rounded-lg border px-3 py-2 text-sm" style="border-color: var(--color-neutral-200);" />
          </div>
          <div>
            <label for="tour-child-name" class="block text-xs font-semibold" style="color: var(--color-neutral-700);">Child&apos;s Name <span aria-hidden="true">*</span></label>
            <input type="text" id="tour-child-name" name="childName" required class="mt-1 w-full rounded-lg border px-3 py-2 text-sm" style="border-color: var(--color-neutral-200);" />
          </div>
          <div>
            <label for="tour-email" class="block text-xs font-semibold" style="color: var(--color-neutral-700);">Email <span aria-hidden="true">*</span></label>
            <input type="email" id="tour-email" name="email" required autocomplete="email" class="mt-1 w-full rounded-lg border px-3 py-2 text-sm" style="border-color: var(--color-neutral-200);" />
          </div>
          <div>
            <label for="tour-phone" class="block text-xs font-semibold" style="color: var(--color-neutral-700);">Phone <span aria-hidden="true">*</span></label>
            <input type="tel" id="tour-phone" name="phone" required autocomplete="tel" class="mt-1 w-full rounded-lg border px-3 py-2 text-sm" style="border-color: var(--color-neutral-200);" />
          </div>
          <div>
            <fieldset>
              <legend class="block text-xs font-semibold" style="color: var(--color-neutral-700);">Child&apos;s Date of Birth</legend>
              <div class="mt-1 grid gap-3 sm:grid-cols-3">
                <input type="text" id="tour-child-dob-month" name="childDobMonth" class="w-full rounded-lg border px-3 py-2 text-sm" style="border-color: var(--color-neutral-200);" placeholder="Month" autocomplete="bday-month" />
                <input type="text" id="tour-child-dob-day" name="childDobDay" inputmode="numeric" class="w-full rounded-lg border px-3 py-2 text-sm" style="border-color: var(--color-neutral-200);" placeholder="Day" autocomplete="bday-day" />
                <input type="text" id="tour-child-dob-year" name="childDobYear" inputmode="numeric" class="w-full rounded-lg border px-3 py-2 text-sm" style="border-color: var(--color-neutral-200);" placeholder="Year" autocomplete="bday-year" />
              </div>
            </fieldset>
          </div>
          <div>
            <label for="tour-message" class="block text-xs font-semibold" style="color: var(--color-neutral-700);">Message (optional)</label>
            <p class="mt-1 text-xs" style="color: var(--color-neutral-500);">
              If these times do not work for you, please add an alternate time in the message and we will do our best to accommodate.
            </p>
            <textarea id="tour-message" name="message" rows={3} class="mt-1 w-full rounded-lg border px-3 py-2 text-sm" style="border-color: var(--color-neutral-200);" placeholder="Any questions, notes, or alternate requested time"></textarea>
          </div>
          <div class="honeypot-field" aria-hidden="true" style="position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden;">
            <label for="tour-website">Leave blank</label>
            <input type="text" id="tour-website" name="website" tabindex="-1" autocomplete="off" />
          </div>
          <button type="submit" class="btn btn-primary btn-icon">
            <Icon name="mail" size={18} /> Send tour request via email
          </button>
        </form>
      </div>

      <!-- Map panel -->
      <div class="lg:col-span-3">
        <div class="media-frame border shadow-sm" style="border-color: var(--color-border);">
          <iframe
            title="Auburn Montessori School location map"
            src={mapEmbedUrl}
            class="h-[20rem] w-full lg:h-[26rem]"
            loading="lazy"
            allowfullscreen=""
            referrerpolicy="no-referrer-when-downgrade"
            style="border:0;"
          ></iframe>
        </div>
      </div>
    </div>
  </div>

  <div class="section-band">
    <div class="container-page mx-auto max-w-3xl">
      <h2 class="section-heading">Contact FAQ</h2>
      <p class="section-subheading">Answers to common contact and location questions</p>
      <div class="mt-6 space-y-4">
        {faqEntries.map((entry) => (
          <div class="card card-body">
            <h3 class="text-sm font-bold" style="color: var(--color-text);">{entry.question}</h3>
            <p class="mt-2 text-sm" style="color: var(--color-neutral-700);">{entry.answer}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- Brightwheel CTA band -->
  <div class="section-band-alt">
    <div class="container-page">
      <div class="cta-panel">
        <div class="flex flex-col items-center gap-4 text-center md:flex-row md:text-left">
          <div class="flex-1">
            <h2 class="text-lg font-bold">Schedule a Tour</h2>
            <p class="mt-1 text-sm" style="color: rgba(255,255,255,0.8);">Start with a classroom visit. Existing families can still sign in to Brightwheel in a new tab.</p>
          </div>
          <a href="/contact#tour-request-form" class="btn btn-primary btn-lg shrink-0">Schedule a Tour</a>
          <ExternalLink href={siteConfig.brightwheel.parentSignInUrl} class="btn btn-outline btn-lg shrink-0" ariaLabel="Parent Sign-In">
            Parent Sign-In
          </ExternalLink>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script define:vars={{ siteEmail: site.email }}>
  const form = document.getElementById('tour-request-form');
  if (form) {
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const honeypot = form.querySelector('input[name="website"]');
      if (honeypot && (honeypot.value || '').trim() !== '') return;

      const parentName = (form.querySelector('#tour-parent-name')?.value || '').trim();
      const childName = (form.querySelector('#tour-child-name')?.value || '').trim();
      const email = (form.querySelector('#tour-email')?.value || '').trim();
      const phone = (form.querySelector('#tour-phone')?.value || '').trim();
      const childDobMonth = (form.querySelector('#tour-child-dob-month')?.value || '').trim();
      const childDobDay = (form.querySelector('#tour-child-dob-day')?.value || '').trim();
      const childDobYear = (form.querySelector('#tour-child-dob-year')?.value || '').trim();
      const message = (form.querySelector('#tour-message')?.value || '').trim();
      const childDob = [childDobMonth, childDobDay, childDobYear].filter(Boolean).join(' / ');

      const subject = encodeURIComponent(`Tour request – ${parentName || 'Auburn Montessori School'}`);
      const lines = [
        "I would like to schedule a tour of Auburn Montessori School - The Children's House.",
        'Available tour times: Weekdays at 11:00am, 1:30pm, or 2:30pm',
        'If these times do not work for us, we will include an alternate time in the message.',
        '',
        'Parent/Guardian Name: ' + parentName,
        'Child\'s Name: ' + childName,
        'Email: ' + email,
        'Phone: ' + phone,
        childDob ? 'Child\'s Date of Birth: ' + childDob : '',
        message ? '\nMessage:\n' + message : ''
      ];
      const body = encodeURIComponent(lines.filter(Boolean).join('\n'));
      const mailto = `mailto:${siteEmail}?subject=${subject}&body=${body}`;
      window.location.href = mailto;
    });
  }
</script>
