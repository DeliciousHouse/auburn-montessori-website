---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import site from '../data/site.json';
import { getImage } from 'astro:assets';
import logo from '../assets/brand/logo.webp';
import { siteInfo } from '../config/site';
import heroSlide1 from '../assets/hero/slide-1.webp';

type Props = {
  title?: string;
  description?: string;
  noindex?: boolean;
  heroTitle?: string;
  heroLead?: string;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>>;
};

const { title, description, noindex, heroTitle, heroLead, structuredData } = Astro.props as Props;

const pageTitle = title
  ? `${title} | ${site.shortName}`
  : `${site.shortName} - ${site.tagline}`;

const pageDescription = description ?? site.description;

const siteBase = Astro.site?.toString() ?? siteInfo.canonicalBaseUrl;
const canonicalUrl = new URL(Astro.url.pathname, siteBase).toString();

const ogImageUrl = new URL(logo.src, siteBase).toString();

const isHomePage = Astro.url.pathname === '/';
const structuredDataList = Array.isArray(structuredData)
  ? structuredData
  : structuredData
    ? [structuredData]
    : [];
const heroSizes = '(min-width: 1024px) 900px, 100vw';
const heroWidths = [480, 640, 768, 960, 1280];
const heroPreloadEntries = isHomePage
  ? await Promise.all(heroWidths.map(async (width) => {
      const image = await getImage({ src: heroSlide1, width, format: 'webp' });
      return `${image.src} ${width}w`;
    }))
  : [];
const heroPreloadSrcset = heroPreloadEntries.join(', ');
const heroPreloadHref = heroPreloadEntries.length
  ? heroPreloadEntries[heroPreloadEntries.length - 1]?.split(' ')[0] ?? ''
  : '';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="preload" href="/fonts/inter-latin-400-normal.woff2" as="font" type="font/woff2" crossorigin />
    {isHomePage && heroPreloadHref ? (
      <link
        rel="preload"
        as="image"
        href={heroPreloadHref}
        imagesrcset={heroPreloadSrcset}
        imagesizes={heroSizes}
        fetchpriority="high"
      />
    ) : null}
    <meta name="generator" content={Astro.generator} />

    <title>{pageTitle}</title>
    <meta name="description" content={pageDescription} />
    <link rel="canonical" href={canonicalUrl} />
    {noindex ? <meta name="robots" content="noindex,nofollow" /> : null}

    <meta property="og:site_name" content={site.shortName} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={pageDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={String(logo.width)} />
    <meta property="og:image:height" content={String(logo.height)} />

    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={pageDescription} />
    <meta name="twitter:url" content={canonicalUrl} />
    <meta name="twitter:image" content={ogImageUrl} />
    {structuredDataList.map((entry) => (
      <script type="application/ld+json" set:html={JSON.stringify(entry)}></script>
    ))}
  </head>
  <body class="flex min-h-screen flex-col">
    <a class="skip-link" href="#main">Skip to content</a>

    <Header currentPath={Astro.url.pathname} />

    {heroTitle ? (
      <div class="hero-band">
        <div class="container-page">
          <h1>{heroTitle}</h1>
          {heroLead ? <p class="hero-lead">{heroLead}</p> : null}
        </div>
      </div>
    ) : null}

    <main id="main" class="flex-1">
      <slot />
    </main>

    <Footer />

    <a
      href="#main"
      id="back-to-top"
      class="back-to-top fixed bottom-6 right-6 z-30 rounded-full border bg-white px-4 py-2 text-sm font-medium shadow-md no-underline opacity-0 pointer-events-none transition-opacity focus:opacity-100 focus:pointer-events-auto"
      style="border-color: var(--color-border); color: var(--color-text-muted);"
      aria-label="Back to top"
    >
      Back to top
    </a>
    <script>
      (function () {
        const maybeEl = document.getElementById('back-to-top');
        if (!(maybeEl instanceof HTMLElement)) return;
        const el = maybeEl;
        const showAfter = 400;
        function update() {
          if (window.scrollY > showAfter) {
            el.classList.add('back-to-top-visible');
          } else {
            el.classList.remove('back-to-top-visible');
          }
        }
        window.addEventListener('scroll', update, { passive: true });
        window.addEventListener('load', update);
      })();
    </script>
  </body>
</html>
